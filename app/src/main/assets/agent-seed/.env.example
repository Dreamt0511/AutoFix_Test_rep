# Pocket-Agent 环境变量配置示例
# 复制此文件为.env并修改对应值即可生效

# MCP服务器地址
MCP_SERVER_URL=http://127.0.0.1:7474/mcp

# ==================== LLM 配置 ====================
DEFAULT_LLM_BASE_URL=http://127.0.0.1:8080/v1
LLM_API_KEY=dummy
LLM_MODEL=gelab-zero-4b-preview
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=8000

# ==================== 子Agent（Executor）模型配置 ====================
# 默认与主Agent共用相同模型，如需让子Agent使用不同模型，取消注释并设置以下变量：
# EXECUTOR_LLM_BASE_URL=http://127.0.0.1:11434/v1
# EXECUTOR_API_KEY=ollama
# EXECUTOR_MODEL=qwen2.5:7b
# EXECUTOR_TEMPERATURE=0.3
# EXECUTOR_MAX_TOKENS=8192

# Ollama本地服务地址
# OLLAMA_BASE_URL=http://localhost:11434
